{
  "name": "triangle-scale-visualizer",
  "version": "1.0.0",
  "description": "Interactive scale visualizer for Bass, Guitar & Piano - Mobile App",
  "main": "index.html",
  "scripts": {
    "start": "npx http-server -p 8000",
    "serve": "npx http-server -p 8000",
    "cap:add": "npx cap add",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open",
    "android": "npm run cap:sync && npx cap open android",
    "ios": "npm run cap:sync && npx cap open ios",
    "build:android": "npm run cap:sync && cd android && ./gradlew assembleDebug",
    "build:ios": "npm run cap:sync && npx cap open ios"
  },
  "keywords": [
    "music",
    "scales",
    "bass",
    "guitar",
    "piano",
    "mobile-app",
    "capacitor"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@capacitor/core": "^5.5.0",
    "@capacitor/app": "^5.0.0",
    "@capacitor/haptics": "^5.0.0",
    "@capacitor/keyboard": "^5.0.0",
    "@capacitor/status-bar": "^5.0.0",
    "@capacitor/splash-screen": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/triangle-scale-visualizer.git"
  }
}
